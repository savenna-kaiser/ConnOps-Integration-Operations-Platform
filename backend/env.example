# ─────────────────────────────────────────────────────────────────────────────
# IT-Operations-Platform – Backend Environment
#
# Kopieren nach `.env` und mit echten Werten befüllen. Diese Datei enthält
# KEINE echten Secrets — nur die erwartete Struktur/Variablennamen.
#
# Als "Pflicht" markierte Variablen werden von server.js beim Start geprüft
# (siehe REQUIRED_ENV) — fehlt eine davon, startet der Server nicht.
#
# Hinweis Roadmap Phase 6.3: Secrets sollen künftig per DPAPI verschlüsselt
# werden (betrifft AD_SERVICE_PASSWORD, EXCHANGE_SERVICE_PASSWORD, PG_PASSWORD,
# TOPDESK_APP_PASSWORD, SESSION_SECRET, TOPDESK_WEBHOOK_SECRET). Bis dahin
# gilt: diese Datei niemals mit echten Werten committen (.env ist in
# .gitignore einzutragen, sofern nicht bereits geschehen).
# ─────────────────────────────────────────────────────────────────────────────

# ─── Server ────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# Pflicht — Session-Cookie-Signierschlüssel, langer zufälliger String
SESSION_SECRET=

# Pflicht — Idle-Timeout für Sessions in Minuten
SESSION_IDLE_TIMEOUT_MIN=30

# ─── PostgreSQL (Change-Queue, Organisations-RBAC) ──────────────────────────
# Alle vier Pflicht
PG_HOST=
PG_PORT=5432
PG_DATABASE=
PG_USER=
PG_PASSWORD=

# ─── Active Directory ────────────────────────────────────────────────────────
# Pflicht
AD_DC=musterstadt.example
AD_DOMAIN=MUSTERSTADT
AD_SERVICE_ACCOUNT=Service_AD
AD_SERVICE_PASSWORD=
AD_NEW_USER_INITIAL_PASSWORD=

# OU-Pfade (Distinguished Names) — je nach AD-Struktur anpassen
AD_GROUP_OU=
AD_EXCHANGE_OU=
AD_PRINTER_OU=
AD_INACTIVE_USERS_OU=
AD_INACTIVE_COMPUTERS_OU=

# Optionale CSV-Exporte / Zwischenspeicher (Pfade)
AD_SESSIONS_CSV=
ASSETS_CSV=
DOCUSNAP_CSV=

# ─── Exchange On-Prem ────────────────────────────────────────────────────────
# Pflicht
EXCHANGE_SERVICE_ACCOUNT=Service_Exchange
EXCHANGE_SERVICE_PASSWORD=
# PowerShell-Endpunkt: http://mail1.musterstadt.example/PowerShell/

# ─── Citrix (Delivery Controller) ───────────────────────────────────────────
# Dedizierter Service-Account (wie AD_SERVICE_ACCOUNT/EXCHANGE_SERVICE_ACCOUNT),
# da nicht alle IT-Admins persönlich auf dem Delivery Controller berechtigt sind.
# Braucht: WinRM/PowerShell-Remoting-Recht auf den Controllern + Citrix
# Delegated Administration (mind. Lesen für Sessions, zusätzlich Schreiben
# fürs Beenden von Sessions/Nachrichten senden, falls Logoff genutzt wird).
CITRIX_SERVICE_ACCOUNT=
CITRIX_SERVICE_PASSWORD=

# ─── PowerShell-Worker-Pool (psWorker.ps1) ──────────────────────────────────
PS_POOL_SIZE=
PS_CMD_TIMEOUT=
PS_HEALTH_TIMEOUT=
PS_MAX_RESTARTS=

# ─── TopDesk ─────────────────────────────────────────────────────────────────
TOPDESK_URL=https://ticket.musterstadt.example
TOPDESK_USERNAME=TOPDESKAPI
# Application Password, NICHT das normale Login-Passwort des Operators
# (siehe: TopDesk Berechtigungsgruppe mit "REST API" + "Use application passwords")
TOPDESK_APP_PASSWORD=

# Pflicht — Secret zur Verifikation eingehender TopDesk-Webhooks
TOPDESK_WEBHOOK_SECRET=

# Status-Filter für zu verarbeitende Changes (Default siehe topdeskClient.js)
TOPDESK_PROCESS_STATUS=1 - Zu bearbeiten

# Template-IDs (Defaults im Code hinterlegt, hier nur bei Bedarf überschreiben)
TOPDESK_TEMPLATE_EINTRITT=aa16e90a-97f7-4b5f-9ef2-2fd7f0f80f3c
TOPDESK_TEMPLATE_AUSTRITT=3ebc323a-eb81-4211-b576-2e72af2ac322
TOPDESK_TEMPLATE_ABT_WECHSEL=3b8b64dc-3f36-4ddd-a951-b86630ebf95e

# Scheduler (holt Changes nur ab, führt nicht automatisch aus)
TOPDESK_CRON_ENABLED=
TOPDESK_CRON_INTERVAL_MIN=

# ─── RBAC (AD-Gruppen → Applikationsrollen) ─────────────────────────────────
RBAC_GROUP_IT_LEADS=
RBAC_GROUP_IT_ADMINS=
RBAC_GROUP_HELPDESK=
RBAC_IT_LEADS=
RBAC_IT_ADMINS=
RBAC_HELPDESK=

# ─── Health-Page-Schwellenwerte ──────────────────────────────────────────────
HEALTH_EXPIRING_DAYS=
HEALTH_INACTIVE_DAYS=
HEALTH_TOPDESK_TIMEOUT=
HEALTH_WAL_WARN_BYTES=
